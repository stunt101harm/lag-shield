NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info
HTTP_BODY_LIMIT_BYTES=65536
HTTP_RATE_LIMIT_MAX=300
DATABASE_URL=postgresql://lagshield:lagshield@localhost:5432/lagshield
PUBLIC_WEB_ORIGIN=http://localhost:3000
# Split-host providers can inject a hostname when URL interpolation is unavailable.
# Cloudflare production uses one origin and does not need this fallback.
# PUBLIC_WEB_HOST=lag-shield.example.workers.dev
NEXT_PUBLIC_LAGSHIELD_API_URL=http://localhost:4000
# NEXT_PUBLIC_LAGSHIELD_API_HOST=lagshield-agent.example.com
# Set this to the final public origin before a social-metadata production build.
# NEXT_PUBLIC_LAGSHIELD_WEB_URL=https://lag-shield.example.workers.dev

# TxLINE defaults to devnet. API tokens belong in a chmod 600 credentials file,
# never in this file or a command-line argument.
TXLINE_NETWORK=devnet
TXLINE_RPC_URL=https://api.devnet.solana.com
TXLINE_CREDENTIALS_FILE=.txline/devnet.credentials.json
TXLINE_CREDENTIALS_SOURCE=file
TXLINE_LIVE_ENABLED=false
TXLINE_PROOF_INTERVAL_MS=10000
# For cloud secret stores, set source=environment and inject both values without committing them.
# TXLINE_API_TOKEN=
# TXLINE_WALLET_PUBLIC_KEY=

# Bounded historical raw-payload cleanup. Derived events, decisions, receipts, and hashes
# remain durable after the expiring upstream payload body is purged.
RETENTION_PURGE_BATCH_SIZE=1000
RETENTION_PURGE_INTERVAL_MS=300000
