{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".prettierrc.json",
    "eslint.config.mjs",
    "package.json",
    "pnpm-lock.yaml",
    "tsconfig.base.json"
  ],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": ["TEST_DATABASE_URL"],
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "env": ["TEST_DATABASE_URL"],
      "outputs": ["coverage/**"]
    }
  }
}
