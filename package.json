{
  "name": "lag-shield",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous, proof-backed circuit breaker for in-play sports markets powered by TxLINE.",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.19.0 <26",
    "pnpm": ">=11.9.0 <12"
  },
  "scripts": {
    "build": "turbo run build",
    "build:agent": "pnpm --filter @lagshield/agent... build",
    "check": "pnpm format:check && pnpm docs:check && pnpm security:scan && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm cloudflare:check && pnpm db:check",
    "cloudflare:check": "pnpm --filter @lagshield/cloudflare check",
    "cloudflare:deploy": "pnpm --filter @lagshield/web... build && pnpm --filter @lagshield/cloudflare deploy",
    "cloudflare:tail": "pnpm --filter @lagshield/cloudflare tail",
    "db:check": "pnpm --filter @lagshield/agent db:check",
    "db:generate": "pnpm --filter @lagshield/agent db:generate",
    "db:migrate": "pnpm --filter @lagshield/agent db:migrate",
    "db:studio": "pnpm --filter @lagshield/agent db:studio",
    "dev": "pnpm build:agent && turbo run dev --parallel",
    "docs:check": "node scripts/check-docs.mjs",
    "evaluation:seeded": "pnpm build:agent && pnpm --filter @lagshield/agent evaluation:seeded",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "judge:smoke": "pnpm build:agent && pnpm --filter @lagshield/agent judge:smoke",
    "lint": "turbo run lint",
    "load:smoke": "pnpm build:agent && pnpm --filter @lagshield/agent load:smoke",
    "replay:seeded": "pnpm build:agent && pnpm --filter @lagshield/agent replay:seeded",
    "security:audit": "pnpm audit --prod --audit-level high",
    "security:scan": "node scripts/scan-secrets.mjs",
    "submission:preflight": "pnpm build:agent && pnpm --filter @lagshield/agent submission:preflight",
    "replay:hydrate": "pnpm build:agent && pnpm --filter @lagshield/agent replay:hydrate",
    "test": "turbo run test",
    "test:e2e": "pnpm build:agent && pnpm --filter @lagshield/web test:e2e",
    "test:coverage": "turbo run test:coverage",
    "txline": "pnpm build:agent && pnpm --filter @lagshield/txline cli",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "globals": "^16.5.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
